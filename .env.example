# Autoskool CLI public-safe example configuration.
# Copy to .env for local development. Never commit real cookies or tokens.

AUTOSKOOL_HOME=./state
AUTOSKOOL_DEFAULT_COMMUNITY=
AUTOSKOOL_BROWSER_CHANNEL=msedge
AUTOSKOOL_REQUIRE_APPROVAL=true
AUTOSKOOL_MIN_DELAY_MINUTES=3
AUTOSKOOL_MAX_DELAY_MINUTES=8
